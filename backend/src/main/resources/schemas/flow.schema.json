{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "flow-schema",
  "type": "object",
  "required": [
    "id",
    "version",
    "canonical_name",
    "title",
    "start_role",
    "approver_role",
    "start_node_id",
    "nodes"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "canonical_name": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "start_role": { "type": "string", "minLength": 1 },
    "approver_role": { "type": "string", "minLength": 1 },
    "start_node_id": { "type": "string", "minLength": 1 },
    "rule_refs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "nodes": {
      "type": "array",
      "items": { "type": "object" },
      "minItems": 1
    }
  },
  "additionalProperties": true
}
