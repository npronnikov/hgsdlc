{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "node-human-input-gate-schema",
  "type": "object",
  "required": [
    "id",
    "title",
    "type",
    "instruction",
    "produced_artifacts",
    "on_submit"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "type": { "type": "string", "enum": ["human_input"] },
    "instruction": { "type": "string" },
    "response_schema": { "type": "object" },
    "produced_artifacts": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/path_requirement" }
    },
    "expected_mutations": {
      "type": "array",
      "items": { "$ref": "#/$defs/path_requirement" }
    },
    "input_artifact": { "type": "string" },
    "output_artifact": { "type": "string" },
    "allowed_roles": { "type": "array" },
    "completion_policy": { "type": "object" },
    "on_submit": { "type": "string" }
  },
  "$defs": {
    "path_requirement": {
      "type": "object",
      "required": ["path", "required"],
      "properties": {
        "path": { "type": "string" },
        "scope": { "type": "string", "enum": ["run"] },
        "required": { "const": true }
      }
    }
  },
  "additionalProperties": true
}
