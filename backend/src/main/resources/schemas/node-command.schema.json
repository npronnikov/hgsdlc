{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "node-command-schema",
  "type": "object",
  "required": [
    "id",
    "title",
    "type",
    "checkpoint_before_run"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "type": { "type": "string", "enum": ["command"] },
    "execution_context": {
      "type": "array",
      "items": { "$ref": "#/$defs/execution_context_entry" }
    },
    "instruction": { "type": "string" },
    "checkpoint_before_run": { "type": "boolean" },
    "response_schema": { "type": "object" },
    "produced_artifacts": {
      "type": "array",
      "items": { "$ref": "#/$defs/path_requirement" }
    },
    "expected_mutations": {
      "type": "array",
      "items": { "$ref": "#/$defs/path_requirement" }
    },
    "command_engine": { "type": "string" },
    "command_spec": { "type": "object" },
    "success_exit_codes": { "type": "array" },
    "on_success": { "type": "string" },
    "retry_policy": { "type": "object" },
    "idempotent": { "type": "boolean" }
  },
  "$defs": {
    "execution_context_entry": {
      "type": "object",
      "required": ["type", "required"],
      "properties": {
        "type": { "type": "string" },
        "path": { "type": "string" },
        "scope": { "type": "string", "enum": ["project", "run"] },
        "required": { "type": "boolean" },
        "node_id": { "type": "string" },
        "transfer_mode": { "type": "string", "enum": ["by_ref", "by_value"] }
      }
    },
    "path_requirement": {
      "type": "object",
      "required": ["path", "required"],
      "properties": {
        "path": { "type": "string" },
        "scope": { "type": "string", "enum": ["project", "run"] },
        "required": { "type": "boolean" },
        "modifiable": { "type": "boolean" }
      }
    }
  },
  "additionalProperties": true
}
