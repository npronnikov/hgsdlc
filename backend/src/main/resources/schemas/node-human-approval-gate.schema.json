{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "node-human-approval-gate-schema",
  "type": "object",
  "required": [
    "id",
    "title",
    "type",
    "execution_context"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "type": { "type": "string", "enum": ["human_approval"] },
    "execution_context": {
      "type": "array",
      "items": { "$ref": "#/$defs/execution_context_entry" }
    },
    "instruction": { "type": "string" },
    "response_schema": { "type": "object" },
    "produced_artifacts": {
      "type": "array",
      "items": { "$ref": "#/$defs/path_requirement" }
    },
    "expected_mutations": {
      "type": "array",
      "items": { "$ref": "#/$defs/path_requirement" }
    },
    "review_artifacts": { "type": "array" },
    "allowed_actions": { "type": "array" },
    "allowed_roles": { "type": "array" },
    "on_approve": { "type": "string" },
    "on_rework": {
      "type": "object",
      "properties": {
        "keep_changes": { "type": "boolean" },
        "next_node": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    }
  },
  "$defs": {
    "execution_context_entry": {
      "type": "object",
      "required": ["type", "required"],
      "properties": {
        "type": { "type": "string" },
        "path": { "type": "string" },
        "scope": { "type": "string", "enum": ["project", "run"] },
        "required": { "type": "boolean" },
        "node_id": { "type": "string" }
      }
    },
    "path_requirement": {
      "type": "object",
      "required": ["path", "required"],
      "properties": {
        "path": { "type": "string" },
        "scope": { "type": "string", "enum": ["project", "run"] },
        "required": { "type": "boolean" },
        "modifiable": { "type": "boolean" }
      }
    }
  },
  "additionalProperties": true
}
