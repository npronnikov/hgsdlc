{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "node-ai-schema",
  "type": "object",
  "required": [
    "id",
    "title",
    "type",
    "execution_context",
    "on_success",
    "on_failure"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "type": { "type": "string", "enum": ["ai"] },
    "execution_context": {
      "type": "array",
      "items": { "$ref": "#/$defs/execution_context_entry" }
    },
    "instruction": { "type": "string" },
    "checkpoint_before_run": { "type": "boolean" },
    "skill_refs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "response_schema": { "type": "object" },
    "produced_artifacts": {
      "type": "array",
      "items": { "$ref": "#/$defs/path_requirement" }
    },
    "expected_mutations": {
      "type": "array",
      "items": { "$ref": "#/$defs/path_requirement" }
    },
    "on_success": { "type": "string" },
    "on_failure": { "type": "string" }
  },
  "$defs": {
    "execution_context_entry": {
      "type": "object",
      "required": ["type", "required"],
      "properties": {
        "type": { "type": "string" },
        "path": { "type": "string" },
        "scope": { "type": "string", "enum": ["project", "run"] },
        "required": { "type": "boolean" },
        "node_id": { "type": "string" }
      }
    },
    "path_requirement": {
      "type": "object",
      "required": ["path", "required"],
      "properties": {
        "path": { "type": "string" },
        "scope": { "type": "string", "enum": ["project", "run"] },
        "required": { "type": "boolean" },
        "modifiable": { "type": "boolean" }
      }
    }
  },
  "additionalProperties": true
}
